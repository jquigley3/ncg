FROM node:22-slim
RUN apt-get update && apt-get install -y curl git && rm -rf /var/lib/apt/lists/*
RUN npm install -g @anthropic-ai/claude-code
RUN mkdir -p /workspace/project /home/node/.claude
# Per-tool proxy config (no HTTP_PROXY/HTTPS_PROXY). Credential injection via reverse proxy (ANTHROPIC_BASE_URL).
RUN printf 'proxy=http://ncg-proxy:3100\nhttps-proxy=http://ncg-proxy:3100\nno-proxy=ncg-proxy\n' > /home/node/.npmrc && \
    printf 'proxy = "http://ncg-proxy:3100"\nnoproxy = "ncg-proxy"\n' > /home/node/.curlrc
RUN git config --global user.name "ncg-worker" \
    && git config --global user.email "worker@ncg.local"
RUN printf '#!/bin/sh\nif [ ! -f /home/node/.claude.json ]; then\n  echo '\''{"installMethod":"npm"}'\'' > /home/node/.claude.json\nfi\nexec "$@"\n' > /usr/local/bin/entrypoint.sh \
    && chmod +x /usr/local/bin/entrypoint.sh
RUN chown -R node:node /workspace /home/node
USER node
WORKDIR /workspace/project
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["bash"]
